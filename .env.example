# Better Auth
BETTER_AUTH_SECRET=replace-with-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:3000
AUTH_DATABASE_URL=file:data/auth.db

# MPF GraphQL API
MPF_API_URL=https://test-api.myperfectfit.co.in:6699/graphql
# Client-visible API URL (used for logoutStylist from the browser)
NEXT_PUBLIC_MPF_API_URL=https://test-api.myperfectfit.co.in:6699/graphql

# Public share links (WhatsApp trail / order details)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Naira AI costing API (server-only; proxied via /api/naira/costs/*)
NAIRA_API_URL=https://nyraapi.myperfectfit.co.in

# Nyra chat embed (browser-visible; include auto-login query params)
NEXT_PUBLIC_NAIRA_CHAT_URL=https://nyra.myperfectfit.co.in/chat?autoLoginUser=YOUR_USER&adminSecret=YOUR_SECRET

# Look Book embed (Style Club admin; defaults to legacy URL if unset)
NEXT_PUBLIC_LOOKBOOK_URL=https://mystyleclub-admin.vercel.app/admin2-lookbook-view

# Style Club GraphQL (order item lookbook picker; defaults to legacy API if unset)
NEXT_PUBLIC_STYLECLUB_GRAPHQL_URL=https://api.mpfstyleclub.com/graphql

# Uppy Companion (S3 image uploads — same as legacy)
NEXT_PUBLIC_COMPANION_URL=https://imageupload.mpfstyleclub.com

# System health runner (optional cron + customer-scoped checks)
# HEALTH_RUN_SECRET=long-random-secret
# HEALTH_MPF_ACCESS_TOKEN=mpf-bearer-token-for-cron
# HEALTH_TEST_CUSTOMER_ID=mongo-customer-user-id
HEALTH_DATABASE_URL=file:data/health.db

# Per-user AG Grid column presets
PREFS_DATABASE_URL=file:data/prefs.db

# Portal maintenance announcements (optional realtime via Ably)
# Create an app at https://ably.com — use a publish-capable key server-side
# and a subscribe-only key for the browser when possible.
# Key capability must allow channel "mpfadmin-maintenance" (or "*").
# ABLY_API_KEY=
# NEXT_PUBLIC_ABLY_KEY=
# NEXT_PUBLIC_ABLY_MAINTENANCE_CHANNEL=mpfadmin-maintenance
# Emergency lock without DB: MAINTENANCE_FORCE_ACTIVE=true
# MAINTENANCE_FORCE_ACTIVE=false

# PostHog product analytics + error tracking (optional — leave unset to disable)
# Create a project at https://us.posthog.com (or eu.posthog.com)
# Project settings → Error tracking: enable exception autocapture
# Session replay: sampleRate 1 + network headers/bodies (redacted). Off: NEXT_PUBLIC_POSTHOG_SESSION_REPLAY=false
# Network payloads are NOT captured on localhost by PostHog — use a deployed host to verify.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# NEXT_PUBLIC_POSTHOG_DISABLED=true
# NEXT_PUBLIC_POSTHOG_SESSION_REPLAY=false

