# Better Auth
BETTER_AUTH_SECRET=replace-with-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:3000
AUTH_DATABASE_URL=file:data/auth.db

# MPF GraphQL API
MPF_API_URL=https://test-api.myperfectfit.co.in:6699/graphql
# Client-visible API URL (used for logoutStylist from the browser)
NEXT_PUBLIC_MPF_API_URL=https://test-api.myperfectfit.co.in:6699/graphql

# Public share links (WhatsApp trail / order details)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Naira AI costing API (server-only; proxied via /api/naira/costs/*)
NAIRA_API_URL=https://nyraapi.myperfectfit.co.in

# Nyra chat embed (browser-visible; include auto-login query params)
NEXT_PUBLIC_NAIRA_CHAT_URL=https://nyra.myperfectfit.co.in/chat?autoLoginUser=YOUR_USER&adminSecret=YOUR_SECRET

# Uppy Companion (S3 image uploads — same as legacy)
NEXT_PUBLIC_COMPANION_URL=https://imageupload.mpfstyleclub.com

# System health runner (optional cron + customer-scoped checks)
# HEALTH_RUN_SECRET=long-random-secret
# HEALTH_MPF_ACCESS_TOKEN=mpf-bearer-token-for-cron
# HEALTH_TEST_CUSTOMER_ID=mongo-customer-user-id
HEALTH_DATABASE_URL=file:data/health.db

